# ============================================================
# LiteLLM 统一 LLM 网关配置模板
#
# 用法:
#   cp configs/litellm_config.yaml.example configs/litellm_config.yaml
#   编辑 configs/litellm_config.yaml，填写内网 API 信息
#   bash scripts/manage.sh up --llm
#
# 访问路径: https://<IP>:8443/llm/
#   Anthropic 格式: /llm/v1/messages      供 Claude Code CLI 使用
#   OpenAI 格式:   /llm/v1/chat/completions  供 Cline / Roo Code 等使用
#
# Claude Code（workspace 内配置）:
#   ANTHROPIC_BASE_URL=https://<IP>:8443/llm
#   ANTHROPIC_API_KEY=sk-devenv              （与 LITELLM_MASTER_KEY 一致）
# ============================================================

model_list:
  # Claude Code 请求的 Anthropic 模型名
  - model_name: claude-opus-4-6
    litellm_params:
      model: openai/YOUR_INTERNAL_MODEL    # 替换为内网实际模型标识
      api_base: "os.environ/INTERNAL_API_BASE"
      api_key: "os.environ/INTERNAL_API_KEY"

  - model_name: claude-sonnet-4-6
    litellm_params:
      model: openai/YOUR_INTERNAL_MODEL
      api_base: "os.environ/INTERNAL_API_BASE"
      api_key: "os.environ/INTERNAL_API_KEY"

  - model_name: claude-haiku-4-5
    litellm_params:
      model: openai/YOUR_INTERNAL_MODEL
      api_base: "os.environ/INTERNAL_API_BASE"
      api_key: "os.environ/INTERNAL_API_KEY"

  # 兼容 Cline / Roo Code 的 OpenAI 模型名
  - model_name: gpt-4o
    litellm_params:
      model: openai/YOUR_INTERNAL_MODEL
      api_base: "os.environ/INTERNAL_API_BASE"
      api_key: "os.environ/INTERNAL_API_KEY"

  - model_name: gpt-4o-mini
    litellm_params:
      model: openai/YOUR_INTERNAL_MODEL
      api_base: "os.environ/INTERNAL_API_BASE"
      api_key: "os.environ/INTERNAL_API_KEY"

litellm_settings:
  drop_params: true       # 忽略不支持的参数
  request_timeout: 600    # 长上下文请求超时（秒）
  num_retries: 2

general_settings:
  # master_key 通过环境变量 LITELLM_MASTER_KEY 注入
  disable_spend_logs: true   # 内存模式，无需数据库
