# LiteLLM acts as an adapter in front of existing internal model infrastructure.
# It does not download or host local models in this repository.
#
# Usage:
#   1. Copy this file to configs/litellm_config.yaml
#   2. Replace YOUR_INTERNAL_MODEL with the real backend model id
#   3. Set INTERNAL_API_BASE and INTERNAL_API_KEY in docker/.env
#   4. Start the platform with LiteLLM enabled
#
# Exposed paths:
#   /llm/v1/messages
#   /llm/v1/chat/completions

model_list:
  - model_name: claude-opus-4-6
    litellm_params:
      model: openai/YOUR_INTERNAL_MODEL
      api_base: "os.environ/INTERNAL_API_BASE"
      api_key: "os.environ/INTERNAL_API_KEY"

  - model_name: claude-sonnet-4-6
    litellm_params:
      model: openai/YOUR_INTERNAL_MODEL
      api_base: "os.environ/INTERNAL_API_BASE"
      api_key: "os.environ/INTERNAL_API_KEY"

  - model_name: claude-haiku-4-5
    litellm_params:
      model: openai/YOUR_INTERNAL_MODEL
      api_base: "os.environ/INTERNAL_API_BASE"
      api_key: "os.environ/INTERNAL_API_KEY"

  - model_name: gpt-4o
    litellm_params:
      model: openai/YOUR_INTERNAL_MODEL
      api_base: "os.environ/INTERNAL_API_BASE"
      api_key: "os.environ/INTERNAL_API_KEY"

  - model_name: gpt-4o-mini
    litellm_params:
      model: openai/YOUR_INTERNAL_MODEL
      api_base: "os.environ/INTERNAL_API_BASE"
      api_key: "os.environ/INTERNAL_API_KEY"

litellm_settings:
  drop_params: true
  request_timeout: 600
  num_retries: 2

general_settings:
  disable_spend_logs: true
