# ============================================================
# Coder Workspace 闂€婊冨剼
# 閸╄桨绨?agentic_web_dev 閻ㄥ嫬绁甸崗銉ョ础瀵偓閸欐垹骞嗘晶鍐╂暭闁姾鈧本娼甸敍?#   - 娣囨繄鏆€鐎瑰本鏆ｅ畵灞藉弳瀵繐浼愰崗鐑芥懠閿涘湏RM GNU閵嗕竼lang閵嗕副penOCD閵嗕傅EMU 缁涘绱?#   - 娣囨繄鏆€ Claude Code CLI + VS Code 閹碘晛鐫?#   - 缁夊娅?nginx/filebrowser閿涘牏鏁?Coder 楠炲啿褰寸仦鍌滎吀閻炲棴绱?#   - 閺?ENTRYPOINT閿涘牏鏁?Coder init_script 閹恒儳顓搁崥顖氬З閿?#   - code-server 娴ｈ法鏁?--auth none閿涘湑oder 鐠愮喕鐭楃拋銈堢槈閿?#
# 閺嬪嫬缂撴稉濠佺瑓閺傚浄绱版い鍦窗閺嶅湱娲拌ぐ鏇礄docker build -f docker/Dockerfile.workspace .閿?# ============================================================

ARG CODE_SERVER_BASE_IMAGE_REF=codercom/code-server:latest
FROM ${CODE_SERVER_BASE_IMAGE_REF}

USER root

# ============================================================
# 閸掑洦宕查崚浼存▼闁插奔绨梹婊冨剼閿涘牐袙閸愬厖鑵戦崶钘夈亣闂勫棛缍夌紒婊堟６妫版﹫绱濋崗鐓庮啇 Ubuntu/Debian閿?# 閸愬懐缍夐弸鍕紦閺冭泛褰插▔銊╁櫞濮濄倖顔岄敍灞煎▏閻劌鍞寸純?apt 濠?# ============================================================
RUN if [ -f /etc/apt/sources.list ] && grep -q "ubuntu" /etc/apt/sources.list 2>/dev/null; then \
        sed -i 's|http://archive.ubuntu.com/ubuntu|http://mirrors.aliyun.com/ubuntu|g' /etc/apt/sources.list && \
        sed -i 's|http://security.ubuntu.com/ubuntu|http://mirrors.aliyun.com/ubuntu|g' /etc/apt/sources.list; \
    elif [ -f /etc/apt/sources.list.d/debian.sources ]; then \
        sed -i 's|http://deb.debian.org/debian|http://mirrors.aliyun.com/debian|g' /etc/apt/sources.list.d/debian.sources && \
        sed -i 's|http://security.debian.org/debian-security|http://mirrors.aliyun.com/debian-security|g' /etc/apt/sources.list.d/debian.sources; \
    elif [ -f /etc/apt/sources.list ]; then \
        sed -i 's|http://deb.debian.org/debian|http://mirrors.aliyun.com/debian|g' /etc/apt/sources.list && \
        sed -i 's|http://security.debian.org|http://mirrors.aliyun.com/debian-security|g' /etc/apt/sources.list; \
    fi

# ============================================================
# apt 缂冩垹绮剁搾鍛娑撳酣鍣哥拠鏇㈠帳缂?# ============================================================
RUN printf 'Acquire::http::Timeout "120";\nAcquire::https::Timeout "120";\nAcquire::Retries "5";\n' \
    > /etc/apt/apt.conf.d/99network-resilience

# ============================================================
# 缁崵绮烘笟婵婄 + 瀹撳苯鍙嗗蹇撶磻閸欐垵鐔€绾偓瀹搞儱鍙?# ============================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    wget \
    git \
    git-lfs \
    vim \
    nano \
    htop \
    tree \
    jq \
    unzip \
    zip \
    build-essential \
    gdb \
    gdb-multiarch \
    cmake \
    ninja-build \
    clang \
    clang-format \
    clang-tidy \
    clang-tools \
    clangd \
    llvm \
    cppcheck \
    valgrind \
    lcov \
    doxygen \
    graphviz \
    gcc-arm-linux-gnueabihf \
    g++-arm-linux-gnueabihf \
    gcc-aarch64-linux-gnu \
    g++-aarch64-linux-gnu \
    python3 \
    python3-pip \
    python3-venv \
    openocd \
    stlink-tools \
    libftdi1-dev \
    libhidapi-dev \
    libusb-1.0-0-dev \
    qemu-user-static \
    qemu-system-arm \
    qemu-system-misc \
    binfmt-support \
    check \
    libcmocka-dev \
    libcunit1-dev \
    libgtest-dev \
    splint \
    iwyu \
    scons \
    cpputest \
    ruby \
    ruby-dev \
    pandoc \
    plantuml \
    default-jre-headless \
    && rm -rf /var/lib/apt/lists/*

# ============================================================
# Google Test 閳?娴犲孩绨惍浣虹椽鐠囨垵鐣ㄧ憗?# ============================================================
RUN cd /usr/src/googletest \
    && cmake . \
    && make \
    && make install

# ============================================================
# Python 瀹搞儱鍙?# ============================================================
RUN pip3 install --no-cache-dir --break-system-packages \
    gcovr \
    pyserial \
    pyelftools \
    meson \
    autopep8 \
    doorstop \
    pyocd \
    esptool \
    pyusb \
    pycparser \
    cffi \
    conan \
    sphinx \
    sphinx-rtd-theme \
    breathe \
    exhale \
    lcov-cobertura

# ============================================================
# ARM bare-metal 瀹搞儱鍙块柧鎾呯礄arm-none-eabi閿?# 缁傝崵鍤庨弸鍕紦閿涙艾鐨?arm-gnu-toolchain tar 閸栧懏鏂侀崚?build-artifacts/ 閻╊喖缍?# 楠炶埖娴涢幑顫簰娑?wget 鐞涘奔璐熼敍娆砄PY build-artifacts/arm-gnu-toolchain-*.tar.xz /tmp/arm-toolchain.tar.xz
# ============================================================
ENV ARM_GCC_VERSION=13.2.rel1
RUN mkdir -p /opt/toolchains \
    && wget -q --timeout=300 \
       "https://developer.arm.com/-/media/Files/downloads/gnu/${ARM_GCC_VERSION}/binrel/arm-gnu-toolchain-${ARM_GCC_VERSION}-x86_64-arm-none-eabi.tar.xz" \
       -O /tmp/arm-toolchain.tar.xz \
    && tar -xf /tmp/arm-toolchain.tar.xz -C /opt/toolchains \
    && mv /opt/toolchains/arm-gnu-toolchain-*-x86_64-arm-none-eabi /opt/toolchains/arm-none-eabi \
    && rm /tmp/arm-toolchain.tar.xz

ENV PATH="/opt/toolchains/arm-none-eabi/bin:${PATH}"

# ============================================================
# fff (Fake Function Framework) - header-only C mock library
# ============================================================
RUN curl -fsSL \
    "https://raw.githubusercontent.com/meekrosoft/fff/master/fff.h" \
    -o /usr/local/include/fff.h \
    && echo "[INFO] fff installed to /usr/local/include/fff.h"

# ============================================================
# Unity standalone (ThrowTheSwitch) - C unit test framework
# 鍋?Ceedling 涔嬪, 鏀?/usr/local/include 缁欓」鐩洿鎺ュ紩鐢?# ============================================================
ENV UNITY_VERSION=v2.6.0
RUN mkdir -p /opt/unity /usr/local/src \
    && curl -fsSL \
       "https://github.com/ThrowTheSwitch/Unity/archive/refs/tags/${UNITY_VERSION}.tar.gz" \
       | tar -xz --strip-components=1 -C /opt/unity \
    && cp /opt/unity/src/unity.c           /usr/local/src/unity.c \
    && cp /opt/unity/src/unity.h           /usr/local/include/unity.h \
    && cp /opt/unity/src/unity_internals.h /usr/local/include/unity_internals.h \
    && echo "[INFO] Unity ${UNITY_VERSION} installed"

# ============================================================
# Node.js + Claude Code CLI
# 缁傝崵鍤庨弸鍕紦閿涙艾鐨?nodesource 鐎瑰顥婇弴鎸庡床娑撳搫鍞寸純?apt 濠ф劖鍨ㄦ０鍕瑓鏉炵晫娈?.deb 閸?# ============================================================
ENV NODE_MAJOR=20
RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_MAJOR}.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://claude.ai/install.sh | bash

# opencode AI 缂傛牜鐖滈崝鈺傚 CLI閿涘牆褰查柅澶涚礆
RUN npm install -g opencode-ai \
    || echo "[WARN] opencode install failed, skipping"

# ============================================================
# Ceedling 瀹撳苯鍙嗗?C 濞村鐦鍡樼仸閿涘牆瀵橀崥?Unity, CMock, CException閿?# ============================================================
RUN gem install ceedling \
    || echo "[WARN] ceedling install failed, skipping"

# ============================================================
# VS Code 閹碘晛鐫嶉敍鍫濈暔鐟佸懎鍩?seed 閻╊喖缍嶉敍灞肩瑝鐞?volume 鐟曞棛娲婇敍?# workspace-startup.sh 閸氼垰濮╅弮鎯板殰閸斻劌鎮庨獮璺哄煂鐎圭偤妾?extensions 閻╊喖缍?# ============================================================
ENV CODE_SERVER_EXTENSIONS_SEED=/opt/code-server-extensions-seed

RUN mkdir -p ${CODE_SERVER_EXTENSIONS_SEED}

# clangd C/C++ support
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension llvm-vs-code-extensions.vscode-clangd \
    || echo "[WARN] vscode-clangd not available, skipping"
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension marus25.cortex-debug \
    || echo "[WARN] cortex-debug not available, skipping"
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension dan-c-underwood.arm \
    || echo "[WARN] arm extension not available, skipping"
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension zixuanwang.linkerscript \
    || echo "[WARN] linkerscript extension not available, skipping"
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension jbenden.c-cpp-flylint \
    || echo "[WARN] c-cpp-flylint not available, skipping"
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension xaver.clang-format \
    || echo "[WARN] clang-format extension not available, skipping"
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension notskm.clang-tidy \
    || echo "[WARN] clang-tidy extension not available, skipping"
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension cschlosser.doxdocgen \
    || echo "[WARN] doxdocgen not available, skipping"
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension ms-vscode.cmake-tools \
    || echo "[WARN] cmake-tools not available on Open VSX, skipping"
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension twxs.cmake \
    || echo "[WARN] twxs.cmake not available, skipping"
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension eamodio.gitlens \
    || echo "[WARN] gitlens not available, skipping"
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension mhutchie.git-graph \
    || echo "[WARN] git-graph not available, skipping"
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension pkief.material-icon-theme \
    || echo "[WARN] material-icon-theme not available, skipping"
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension streetsidesoftware.code-spell-checker \
    || echo "[WARN] code-spell-checker not available, skipping"
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension usernamehw.errorlens \
    || echo "[WARN] errorlens not available, skipping"
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension christian-kohler.path-intellisense \
    || echo "[WARN] path-intellisense not available, skipping"

# Claude Code 鐎规ɑ鏌熼幍鈺佺潔
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension anthropic.claude-code \
    || echo "[INFO] Claude Code extension not in marketplace, use VSIX instead"

# Cline
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension saoudrizwan.claude-dev \
    || echo "[INFO] Cline not available, skipping"

# Roo Code AI
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension RooVeterinaryInc.roo-cline \
    || echo "[WARN] Roo Code not available, skipping"

# Coverage Gutters
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension ryanluker.vscode-coverage-gutters \
    || echo "[WARN] coverage-gutters not available, skipping"

# PlantUML
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension jebbs.plantuml \
    || echo "[WARN] plantuml not available, skipping"

# Markdown Mermaid
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension bierner.markdown-mermaid \
    || echo "[WARN] markdown-mermaid not available, skipping"

# Markdown All in One
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension yzhang.markdown-all-in-one \
    || echo "[WARN] markdown-all-in-one not available, skipping"

# TODO Tree
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension Gruntfuggly.todo-tree \
    || echo "[WARN] todo-tree not available, skipping"

# Test Explorer UI - framework-agnostic test discovery and runner
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension hbenl.vscode-test-explorer \
    || echo "[WARN] vscode-test-explorer not available, skipping"

# C++ TestMate - Test Adapter for Google Test / Catch2 / doctest / CppUTest
RUN code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension matepek.vscode-catch2-test-adapter \
    || echo "[WARN] vscode-catch2-test-adapter not available, skipping"

# ============================================================
# 缁傝崵鍤?VSIX 鐎瑰顥婇敍鍫濈殺 .vsix 閺傚洣娆㈤弨鎯у煂 configs/vsix/ 閻╊喖缍嶉敍?# 闁倻鏁ゆ禍?Open VSX 濞屸剝婀侀惃鍕⒖鐏炴洩绱欐俊?ms-vscode.cpptools閵嗕工nthropic.claude-code 缁涘绱?# ============================================================
RUN mkdir -p /tmp/vsix
COPY configs/vsix/ /tmp/vsix/
RUN if ls /tmp/vsix/*.vsix 1>/dev/null 2>&1; then \
        for vsix in /tmp/vsix/*.vsix; do \
            echo "Installing: $vsix" && \
            code-server --extensions-dir ${CODE_SERVER_EXTENSIONS_SEED} --install-extension "$vsix" || echo "Failed: $vsix"; \
        done; \
    else \
        echo "[INFO] No VSIX files, skipping offline install"; \
    fi

# ============================================================
# 閸欘垶鈧绱版穱鈥叉崲 Coder 閺堝秴濮熼崳銊ф畱閼奉亞顒烽崥宥堢槈娑?# 鐏?configs/ssl/server.crt 閻ㄥ嫬鍞寸€圭懓濮為崗銉ч兇缂佺喍淇婃禒璇茬摠閸?# 鏉╂瑦鐗?workspace 鐎圭懓娅掓稉顓犳畱 curl閿涘牏鏁ゆ禍搴濈瑓鏉?coder agent閿涘鍏樺锝呯埗妤犲矁鐦夐張宥呭閸ｃ劏鐦夋稊?# 閸撳秵褰侀敍姘帥鏉╂劘顢?manage.sh ssl閿涘苯鍟€鏉╂劘顢?manage.sh build
# ============================================================
RUN mkdir -p /usr/local/share/ca-certificates
COPY configs/ssl/ca.crt /tmp/coder-root-ca.crt
RUN if [ -f /tmp/coder-root-ca.crt ]; then \
        cp /tmp/coder-root-ca.crt /usr/local/share/ca-certificates/coder-platform-root-ca.crt && \
        update-ca-certificates 2>/dev/null && \
        echo "[INFO] Coder platform root CA trusted in workspace image"; \
    else \
        echo "[INFO] No CA cert found (run manage.ps1 ssl or manage.sh ssl before build)"; \
    fi && \
    rm -f /tmp/coder-root-ca.crt

# ============================================================
# VS Code 瀹搞儰缍旈崠娲帛鐠併倛顔曠純?# ============================================================
COPY --chown=coder:coder configs/settings.json /home/coder/.local/share/code-server/User/settings.json

# ============================================================
# 瀹撳苯鍙嗗蹇撲紣閸忓嘲鍩嗛崥宥忕礄閸愭瑥鍙嗙化鑽ょ埠缁?profile閿涘苯顔愰崳銊や簰 root 鏉╂劘顢戦弮鏈电瘍娴兼艾濮炴潪鏂ょ礆
# ============================================================
RUN printf '# ==== Embedded Dev Environment ====\n\
export PATH="/opt/toolchains/arm-none-eabi/bin:$PATH"\n\
alias arm-gcc="arm-none-eabi-gcc"\n\
alias arm-objdump="arm-none-eabi-objdump"\n\
alias arm-size="arm-none-eabi-size"\n\
alias cf="clang-format"\n\
alias ct="clang-tidy"\n\
alias cppc="cppcheck --enable=all --suppress=missingIncludeSystem"\n\
alias cov="gcovr -r . --html --html-details -o coverage.html"\n\
alias sp="splint -weak"\n\
alias iwyu="include-what-you-use"\n\
alias scan="scan-build --use-cc=gcc"\n\
alias ds="doorstop"\n\
alias ceed="ceedling"\n\
alias qemu-arm="qemu-arm-static"\n\
alias flash-openocd="openocd"\n\
alias flash-pyocd="pyocd"\n\
alias esp-flash="esptool.py"\n\
alias sphinx-init="sphinx-quickstart"\n\
alias cov-lcov="lcov --capture --directory . --output-file coverage.info"\n\
alias cov-html="gcovr -r . --html --html-details -o coverage.html"\n\
alias cov-xml="lcov_cobertura coverage.info"\n\
alias unity-src="ls /usr/local/include/unity*.h /usr/local/src/unity.c"\n\
alias fff-src="ls /usr/local/include/fff.h"\n' \
    > /etc/profile.d/embedded-dev.sh \
    && cat /etc/profile.d/embedded-dev.sh >> /etc/bash.bashrc

# ============================================================
# workspace 閸氼垰濮╅懘姘拱閿涘牏鏁?Coder agent startup_script 鐠嬪啰鏁ら敍?# 鐠愮喕鐭楅敍姘跺帳缂?Claude Code + 閸氬牆鑻熼幍鈺佺潔 seed + 閸氼垰濮?code-server
# ============================================================
COPY scripts/workspace-startup.sh /opt/workspace-startup.sh
RUN sed -i 's/\r$//' /opt/workspace-startup.sh && chmod +x /opt/workspace-startup.sh

ENV SHELL=/bin/bash
WORKDIR /home/coder

# 閺?ENTRYPOINT閿涙氨鏁?Coder 閻?init_script 閹恒儳顓哥€圭懓娅掗崗銉ュ經
# init_script 娑撳娴?coder agent 楠炶泛鎯庨崝顭掔礉agent 閸愬秵澧界悰?startup_script
