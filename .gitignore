# ============================================================
# Git 忽略文件
# ============================================================

# 环境配置（含密码和 API Key）
docker/.env
docker/.setup-done

# SSL 证书（含私钥）
configs/ssl/

# Docker 镜像包（体积过大）
images/
*.tar
offline-manifest.json

# 日志
logs/
*.log

# 操作系统临时文件
.DS_Store
Thumbs.db
*~
*.swp

# 编辑器
.vscode/
.idea/

# Python
__pycache__/
*.pyc

# LiteLLM config (may contain real API keys)
configs/litellm_config.yaml

# Offline provider cache (generated by prepare-offline)
configs/terraform-providers/registry.terraform.io/

# Provider mirror zips (large binaries, generated by prepare-offline / update-provider-mirror)
configs/provider-mirror/registry.terraform.io/**/*.zip

# VSIX 扩展包（体积过大）
configs/vsix/*.vsix

# Temp/test scripts
scripts/_*.ps1
scripts/_*.sh
