# 统一文本文件使用 LF，减少跨平台编辑导致的 mixed EOL 和补丁失配
.gitattributes  text eol=lf
.gitignore      text eol=lf
.dockerignore   text eol=lf
.editorconfig   text eol=lf
*.sh         text eol=lf
*.bash       text eol=lf
*.ps1        text eol=lf
*.psm1       text eol=lf
*.psd1       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.json       text eol=lf
*.conf       text eol=lf
*.env        text eol=lf
*.tf         text eol=lf
*.rc         text eol=lf
*.md         text eol=lf
*.example    text eol=lf
Dockerfile*  text eol=lf
