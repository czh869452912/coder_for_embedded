# ============================================================
# Coder 生产平台配置模板
# 复制为 docker/.env 并修改：cp .env.example docker/.env
# 或运行：bash scripts/manage.sh init
# ============================================================

# ---- 网络配置 ----
SERVER_HOST=localhost          # 服务器 IP 或域名（影响 SSL 证书和访问 URL）
GATEWAY_PORT=8443              # 对外暴露的唯一端口

# ---- Coder 镜像版本 ----
CODER_IMAGE=ghcr.io/coder/coder
CODER_VERSION=latest
WORKSPACE_IMAGE=workspace-embedded
WORKSPACE_IMAGE_TAG=latest

# ---- PostgreSQL 数据库 ----
POSTGRES_PASSWORD=CHANGEME_auto_generated_by_init

# ---- Coder 管理员账号 ----
# 首次启动时 manage.sh 自动通过 API 创建
CODER_ADMIN_EMAIL=admin@company.local
CODER_ADMIN_USERNAME=admin
CODER_ADMIN_PASSWORD=CHANGEME_strong_password

# ---- Claude Code API 配置 ----
# 方案A: 官方 Anthropic API
#   ANTHROPIC_API_KEY=sk-ant-api03-...
#   ANTHROPIC_BASE_URL=                   （留空使用 https://api.anthropic.com）
#
# 方案B: 内网 Anthropic 协议代理（实现 /v1/messages 端点）
#   ANTHROPIC_API_KEY=your-proxy-key
#   ANTHROPIC_BASE_URL=http://10.0.0.100:8000
#
# 方案C: LiteLLM 网关（内网 OpenAI 兼容 API 转 Anthropic 格式）
#   ANTHROPIC_API_KEY=sk-devenv           （与 LITELLM_MASTER_KEY 一致）
#   ANTHROPIC_BASE_URL=https://<SERVER_HOST>:<GATEWAY_PORT>/llm
#   启动: bash manage.sh up --llm
#
# 方案D: 留空，用户在 workspace 终端执行 claude 手动登录
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# ---- LiteLLM 统一 AI 网关（--llm 模式启用）----
# 通过 /llm/ 路径暴露给所有 workspace 用户
# 同时支持 Anthropic /v1/messages 和 OpenAI /v1/chat/completions 格式
LITELLM_MASTER_KEY=sk-devenv
INTERNAL_API_BASE=http://10.0.0.1:8000
INTERNAL_API_KEY=your-internal-api-key

# ---- 内部端口（通常不需要修改）----
CODER_INTERNAL_PORT=7080
