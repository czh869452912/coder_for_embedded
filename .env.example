# ============================================================
# Coder 生产平台配置模板
# 复制为 docker/.env 并修改：cp .env.example docker/.env
# 或运行：bash scripts/manage.sh init
# ============================================================

# ---- 网络配置 ----
SERVER_HOST=localhost          # 服务器 IP 或域名（影响 SSL 证书和访问 URL）
GATEWAY_PORT=8443              # 对外暴露的唯一端口

# ---- Coder 镜像版本 ----
CODER_IMAGE=ghcr.io/coder/coder
CODER_VERSION=latest
WORKSPACE_IMAGE=workspace-embedded
WORKSPACE_IMAGE_TAG=latest

# ---- PostgreSQL 数据库 ----
POSTGRES_PASSWORD=CHANGEME_auto_generated_by_init

# ---- Coder 管理员账号 ----
# 首次启动时 manage.sh 自动通过 API 创建
CODER_ADMIN_EMAIL=admin@company.local
CODER_ADMIN_USERNAME=admin
CODER_ADMIN_PASSWORD=CHANGEME_strong_password

# ---- Claude Code API 配置 ----
# 方案A: 官方 Anthropic API（联网环境）
#   ANTHROPIC_API_KEY=sk-ant-api03-...
#   ANTHROPIC_BASE_URL=                   （留空，Claude Code 默认访问 https://api.anthropic.com）
#
# 方案B: 内网 Anthropic 协议代理（实现 /v1/messages 端点）
#   ANTHROPIC_API_KEY=your-proxy-key
#   ANTHROPIC_BASE_URL=http://10.0.0.100:8000
#
# 方案C: LiteLLM 网关（推荐离线/内网环境）
#   workspace 容器与 llm-gateway 同在 coderplatform 网络，通过 Docker DNS 直连
#   无需经过 Nginx HTTPS 网关，避免 SSL 开销和 localhost 解析错误
#   ANTHROPIC_API_KEY=sk-devenv           （与 LITELLM_MASTER_KEY 保持一致）
#   ANTHROPIC_BASE_URL=http://llm-gateway:4000
#   启动: bash manage.sh up --llm
#
# 方案D: 留空，用户在 workspace 终端执行 claude 手动登录
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# ---- LiteLLM 统一 AI 网关（--llm 模式启用）----
# workspace 容器通过 http://llm-gateway:4000 直连（Docker 内网 DNS）
# 同时支持 Anthropic /v1/messages 和 OpenAI /v1/chat/completions 格式
# 外部浏览器/工具也可通过 https://<SERVER_HOST>:<GATEWAY_PORT>/llm/ 访问（经 Nginx 转发）
LITELLM_MASTER_KEY=sk-devenv
INTERNAL_API_BASE=http://10.0.0.1:8000
INTERNAL_API_KEY=your-internal-api-key

# ---- LDAP 身份认证（--ldap 模式启用）----
# 接入企业 LDAP/AD，用户可用域账号直接登录 Coder
# 启动命令: bash manage.sh up --ldap  （Windows: .\manage.ps1 up -Ldap）
#
# Dex 作为 LDAP→OIDC 桥接层，以下变量需全部填写后方可启用：

# OIDC 客户端密钥（Dex 与 Coder 共享，任意随机字符串）
# 生成方式: openssl rand -hex 32
OIDC_CLIENT_SECRET=CHANGEME_generate_with_openssl_rand_hex_32

# 允许登录的邮箱域名（* 表示接受所有来自 LDAP 的邮箱）
# 建议改为你的公司域名，例如: company.local
OIDC_EMAIL_DOMAIN=*

# LDAP 用户首次登录时是否自动创建 Coder 账户
OIDC_ALLOW_SIGNUPS=true

# LDAP 服务器地址（含端口）
# 明文: ldap.company.local:389
# LDAPS（推荐生产使用）: ldaps://ldap.company.local:636
DEX_LDAP_HOST=ldap.company.local:389

# 服务账号（Dex 用于搜索 LDAP 用户的 bind DN 及密码）
# 建议在 LDAP 中创建只读服务账号
DEX_LDAP_BIND_DN=cn=svc-coder,ou=serviceaccounts,dc=company,dc=local
DEX_LDAP_BIND_PW=CHANGEME_ldap_bind_password

# 用户对象搜索根 DN
DEX_LDAP_USER_BASE_DN=ou=users,dc=company,dc=local

# 组对象搜索根 DN（用于 groups claim，可与 USER_BASE_DN 相同）
DEX_LDAP_GROUP_BASE_DN=ou=groups,dc=company,dc=local

# ---- 内部端口（通常不需要修改）----
CODER_INTERNAL_PORT=7080
